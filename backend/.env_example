# ─── Database ────────────────────────────────────────────────────────────────
# Local SQLite (development only):
# DB_URL=sqlite:///./claim360.db
#
# Neon PostgreSQL (recommended free tier for production):
# 1. Sign up at https://neon.tech (free, no credit card)
# 2. Create a project → copy the connection string
# 3. Paste it below (make sure ?sslmode=require is included)
DB_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/claim360?sslmode=require

# ─── JWT Auth ────────────────────────────────────────────────────────────────
# Generate a strong random secret:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-32-chars

# Token lifetime in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin Seed Account ──────────────────────────────────────────────────────
# Created automatically on first startup if it does not exist
ADMIN_EMAIL=admin@claim360.in
ADMIN_PASSWORD=ChangeThisStrongPassword!

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://claim360.in,https://www.claim360.in
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
