# Database
# Local SQLite (development only):
# DB_URL=sqlite:///./claim360.db
#
# PostgreSQL for production:
DB_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT auth
SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin seed account
ADMIN_EMAIL=admin@claim360.in
ADMIN_PASSWORD=ChangeThisStrongPassword!

# Email OTP (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Claim360 <support@claim360.in>

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
